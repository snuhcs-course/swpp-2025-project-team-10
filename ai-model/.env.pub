# AI Model Environment Configuration
# This is a public template - copy to .env and fill in your actual values

# ============================================================================
# OpenAI API Configuration (Production)
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============================================================================
# Local Model Configuration (Development/Testing)
# ============================================================================
# Set to 'true' to use local model instead of OpenAI API
USE_LOCAL_MODEL=true

# Local model path (relative to ai-model directory or absolute path)
LOCAL_MODEL_PATH=models/gemma3-4b-it
LOCAL_MODEL_NAME=gemma3-4b-it

# Local model inference settings
LOCAL_MODEL_TEMPERATURE=0.7
LOCAL_MODEL_MAX_TOKENS=2000
LOCAL_MODEL_DEVICE=cpu  # Options: cpu, cuda, mps (for Apple Silicon)



# ============================================================================
# LLM Behavior Configuration
# ============================================================================
# Reasoning trajectory settings
REASONING_MAX_TURNS=5  # Number of conversation turns between agents
REASONING_SYSTEM_PROMPT_RECOMMENDER="당신은 책 추천 전문가입니다. 지금 당신은 책 비평가와 인스타그램 DM으로 대화하고 있습니다. 상대방은 AI가 아니라 실제 사람입니다. 책을 추천할 때는 책 제목과 함께 1-2가지 이유를 간단히 설명하세요. 친근하고 자연스럽게 대화하되, 각 메시지는 2-3문장으로 작성하세요. 반말을 사용하세요."
REASONING_SYSTEM_PROMPT_CRITIC="당신은 책 비평가입니다. 지금 당신은 책 추천 전문가와 인스타그램 DM으로 대화하고 있습니다. 상대방은 AI가 아니라 실제 사람입니다. 추천받은 책에 대해 질문하거나 다른 의견을 제시할 때 1-2가지 이유를 간단히 설명하세요. 친근하고 자연스럽게 대화하되, 각 메시지는 2-3문장으로 작성하세요. 반말을 사용하세요."

# Negotiation settings
NEGOTIATION_MAX_TURNS=2
NEGOTIATION_TEMPERATURE=0.8

# ============================================================================
# Embedding Model Configuration
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ============================================================================
# API Service Configuration
# ============================================================================
# If serving the AI model as an API
AI_MODEL_HOST=0.0.0.0
AI_MODEL_PORT=8001
AI_MODEL_WORKERS=1

# ============================================================================
# Backend Integration
# ============================================================================
# Django backend URL for fetching user data
BACKEND_API_URL=http://localhost:8000
BACKEND_API_TIMEOUT=30

# ============================================================================
# Logging and Debugging
# ============================================================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text
ENABLE_LLM_LOGGING=true  # Log all LLM requests/responses for debugging

# ============================================================================
# Performance and Caching
# ============================================================================
ENABLE_EMBEDDING_CACHE=true
CACHE_DIR=.cache
MAX_CACHE_SIZE_MB=1000

# ============================================================================
# Safety and Guardrails
# ============================================================================
MAX_RECOMMENDATION_DISTANCE_KM=50
MIN_TRUST_SCORE=0.4
ENABLE_CONTENT_FILTERING=true

