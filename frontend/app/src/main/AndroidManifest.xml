<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LibraryTogether"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".feature.auth.LoginActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".feature.auth.SignupActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.ForgotPasswordActivity"
            android:exported="false" />


        <activity
            android:name=".feature.auth.ResetPasswordActivity"
            android:exported="false" />

        <activity
            android:name=".feature.auth.VerifyEmailActivity"
            android:exported="false" />

        <activity
            android:name="com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- 리다이렉트 URI: "kakao${NATIVE_APP_KEY}://oauth" -->
                <data android:host="oauth"
                    android:scheme="kakaodd8a497c4db87c8907318022920a405c" />
            </intent-filter>
        </activity>

        <activity
            android:name=".feature.main.MainActivity"
            android:exported="false" />

        <activity
            android:name=".util.HiltTestActivity"
            android:exported="false" />

    </application>

</manifest>
