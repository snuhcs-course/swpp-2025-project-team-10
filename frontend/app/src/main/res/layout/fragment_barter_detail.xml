<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.barter.BarterDetailFragment">

    <ImageButton
        android:id="@+id/btnBack"
        style="?attr/borderlessButtonStyle"
        android:layout_width="12dp"
        android:layout_height="wrap_content"
        android:padding="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvTitle"
        style="@style/Text.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="교환 신청하기"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSubmitExchange">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWantBook"
                style="@style/Card.Base"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvWantBookHeader"
                        style="@style/Text.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="교환받을 책" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/profileContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivProfileImage"
                            android:layout_width="@dimen/avatar_s"
                            android:layout_height="@dimen/avatar_s"
                            android:src="@drawable/person_icon"
                            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Circle"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />

                        <TextView
                            android:id="@+id/tvPoster"
                            style="@style/Text.Body"
                            android:textStyle="bold"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_m"
                            tools:text="책주인 닉네임"
                            app:layout_constraintStart_toEndOf="@id/ivProfileImage"
                            app:layout_constraintTop_toTopOf="@id/ivProfileImage"
                            app:layout_constraintBottom_toBottomOf="@id/ivProfileImage"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_m"
                        android:background="?attr/colorOutline"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivBookCoverWant"
                            android:layout_width="100dp"
                            android:layout_height="140dp"
                            android:scaleType="centerCrop"
                            tools:src="@tools:sample/backgrounds/scenic" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/tvBookTitleWant"
                                style="@style/Text.H2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxLines="2"
                                android:ellipsize="end"
                                tools:text="해리 포터와 마법사의 돌" />

                            <TextView
                                android:id="@+id/tvBookAuthorWant"
                                style="@style/Text.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                tools:text="J.K. 롤링" />

                            <TextView
                                android:id="@+id/tvBookConditionWant"
                                style="@style/Text.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                tools:text="상태: 최상 (한 번 읽음)" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOfferBook"
                style="@style/Card.Base"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvOfferBookHeader"
                            style="@style/Text.H2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="교환할 내 책" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChangeBook"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity=""
                            android:minHeight="0dp"
                            android:paddingVertical="0dp"
                            android:text="책 변경하기" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_m"
                        android:background="?attr/colorOutline" />

                    <FrameLayout
                        android:id="@+id/bookSelectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/selectionButtonsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="visible"
                            tools:visibility="gone">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSelectFromLibrary"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="내 서재에서 선택하기" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRegisterNewBook"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="새로운 책 등록하기" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/selectedBookContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/ivBookCoverOffer"
                                    android:layout_width="100dp"
                                    android:layout_height="140dp"
                                    android:scaleType="centerCrop"
                                    tools:src="@tools:sample/backgrounds/scenic" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="16dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvBookTitleOffer"
                                        style="@style/Text.H2"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="내가 가진 다른 책" />

                                    <TextView
                                        android:id="@+id/tvBookAuthorOffer"
                                        style="@style/Text.Body"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        tools:text="작가" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilOfferMessage"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:hint="교환 신청 메시지 (추천의 말)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOfferMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:minLines="4"
                            tools:text="이 책도 정말 재미있습니다. 교환 원해요!" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitExchange"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="교환 신청하기"
        android:layout_margin="16dp"
        app:shapeAppearanceOverlay="@style/Shape.Round12"
        app:backgroundTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
