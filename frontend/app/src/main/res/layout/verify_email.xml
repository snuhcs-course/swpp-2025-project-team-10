<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.auth.ForgotPasswordActivity">

    <TextView
        android:id="@+id/AppNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="서로서로도서관"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="120dp"
        android:layout_marginBottom="90dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/RenewPasswordText"/>

    <TextView
        android:id="@+id/RenewPasswordText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="비밀번호 재설정"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/AppNameText"
        app:layout_constraintBottom_toTopOf="@id/VerifyEmailSubText"/>

    <TextView
        android:id="@+id/VerifyEmailSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="인증번호(6자리)를 입력해 주세요"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/RenewPasswordText" />

    <EditText
        android:id="@+id/VerifyNum1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:maxLength="1"
        android:layout_marginStart="48dp"
        android:layout_marginVertical="20dp"
        android:textAlignment="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/VerifyNum2"
        app:layout_constraintTop_toBottomOf="@id/VerifyEmailSubText"
        app:layout_constraintBottom_toTopOf="@id/VerifyButton"
        app:layout_constraintHorizontal_chainStyle="spread"/>

    <EditText
        android:id="@+id/VerifyNum2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:maxLength="1"
        android:textAlignment="center"
        app:layout_constraintStart_toEndOf="@id/VerifyNum1"
        app:layout_constraintEnd_toStartOf="@id/VerifyNum3"
        app:layout_constraintTop_toTopOf="@id/VerifyNum1"
        app:layout_constraintBottom_toBottomOf="@id/VerifyNum1"/>

    <EditText
        android:id="@+id/VerifyNum3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:maxLength="1"
        android:textAlignment="center"
        app:layout_constraintStart_toEndOf="@id/VerifyNum2"
        app:layout_constraintEnd_toStartOf="@id/VerifyNum4"
        app:layout_constraintTop_toTopOf="@id/VerifyNum1"
        app:layout_constraintBottom_toBottomOf="@id/VerifyNum1"/>

    <EditText
        android:id="@+id/VerifyNum4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:maxLength="1"
        android:textAlignment="center"
        app:layout_constraintStart_toEndOf="@id/VerifyNum3"
        app:layout_constraintEnd_toStartOf="@id/VerifyNum5"
        app:layout_constraintTop_toTopOf="@id/VerifyNum1"
        app:layout_constraintBottom_toBottomOf="@id/VerifyNum1"/>

    <EditText
        android:id="@+id/VerifyNum5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:maxLength="1"
        android:textAlignment="center"
        app:layout_constraintStart_toEndOf="@id/VerifyNum4"
        app:layout_constraintEnd_toStartOf="@id/VerifyNum6"
        app:layout_constraintTop_toTopOf="@id/VerifyNum1"
        app:layout_constraintBottom_toBottomOf="@id/VerifyNum1"/>

    <EditText
        android:id="@+id/VerifyNum6"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:maxLength="1"
        android:textAlignment="center"
        android:layout_marginEnd="48dp"
        app:layout_constraintStart_toEndOf="@id/VerifyNum5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/VerifyNum1"
        app:layout_constraintBottom_toBottomOf="@id/VerifyNum1"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ResendEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="인증메일 재전송"
        android:textSize="12sp"
        android:textColor="#6DB2F6"
        android:backgroundTint="@android:color/transparent"
        android:layout_marginBottom="4dp"
        android:padding="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/VerifyButton"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/VerifyButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#1E1E1E"
        android:text="인증하기"
        android:layout_marginHorizontal="48dp"
        android:layout_marginVertical="20dp"
        app:cornerRadius="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/VerifyNum1" />


</androidx.constraintlayout.widget.ConstraintLayout>