<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearanceOverlay.App.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Shape.Round12" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="Shape.Round4" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>

    <!-- Text -->
    <style name="Text">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="Text.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Text.H1">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Text.H2">
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
    </style>
    <style name="Text.Body.Medium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontWeight">500</item>
    </style>
    <style name="Text.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Text + Leading icon 줄여쓰는 용도 -->
    <style name="Text.WithIcon">
        <item name="android:drawablePadding">@dimen/space_s</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <!-- 카드 공통 -->
    <style name="Card.Base" parent="Widget.Material3.CardView.Outlined">
        <item name="cardUseCompatPadding">true</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
        <item name="shapeAppearanceOverlay">@style/Shape.Round12</item>
    </style>

    <!-- 원형 아바타 -->
    <style name="Avatar.Circle" parent="">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.App.Circle</item>
    </style>

    <style name="Btn.Icon.Base" parent="Widget.Material3.Button.Icon">
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:minWidth">40dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:tint">?attr/colorOnSurfaceVariant</item>
    </style>
    <!-- 액션바 Tonal 버튼(아이콘+텍스트) -->
    <style name="Btn.Tonal.TextIcon" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_height">@dimen/btn_h</item>
        <item name="android:minWidth">0dp</item>
        <item name="iconPadding">@dimen/space_s</item>
        <item name="iconGravity">textStart</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">0dp</item>
    </style>
    <!-- 액션바 Tonal 버튼(텍스트) -->
    <style name="Btn.Tonal.Text" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:paddingHorizontal">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <!-- Chip -->
    <style name="Chip" parent="Widget.Material3.Chip.Assist">
    </style>
    <style name="Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="android:checkable">false</item>
    </style>
    <style name="Chip.Filter" parent="Widget.Material3.Chip.Assist">
        <item name="android:checkable">false</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- 섹션 칩(‘필’ 배경으로 구획감) -->
    <style name="Pill">
        <item name="android:gravity">center</item>
        <item name="shapeAppearanceOverlay">@style/Shape.Round4</item>
    </style>
    <style name="Pill.Section">
        <item name="android:paddingLeft">@dimen/space_s</item>
        <item name="android:paddingRight">@dimen/space_s</item>
        <item name="android:paddingTop">@dimen/space_xs</item>
        <item name="android:paddingBottom">@dimen/space_xs</item>
        <item name="android:background">?attr/colorSurfaceVariant</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:letterSpacing">0.04</item>
    </style>


</resources>
